# =============================================
# さばけ！おさかな AWS設定
# このファイルを .env にコピーして値を設定
# cp .env.example .env
# =============================================

# AWSリージョン
AWS_REGION="ap-northeast-1"

# --- ランキングAPI ---
TABLE_NAME="SabakeLeaderboard"
FUNCTION_NAME="SabakeLeaderboardFunc"
ROLE_NAME="SabakeLeaderboardLambdaRole"
API_NAME="SabakeLeaderboardAPI"

# --- S3ホスティング ---
# バケット名（グローバルで一意にすること）
S3_BUCKET_NAME="sabake-osakana-web"
